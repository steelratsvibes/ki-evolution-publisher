# LinkedIn API
LI_ACCESS_TOKEN=dein_linkedin_token_hier
LI_PERSON_URN=urn:li:person:DEINE_URN
LI_TOKEN_EXPIRES=2026-01-01
LI_CLIENT_ID=deine_linkedin_client_id
LI_CLIENT_SECRET=dein_linkedin_client_secret

# SMTP (für Approval-Emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=dein_smtp_user
SMTP_SENDER=dein@email.com
SMTP_PASSWORD=dein_passwort

# Approval
APPROVAL_TO=empfaenger@email.com

# Apify (für LinkedIn Scraping)
APIFY_TOKEN=dein_apify_token

# OpenAI (für Antwort-Generierung)
OPENAI_API_KEY=dein_openai_key

# IMAP (für Approval-Check)
IMAP_HOST=imap.example.com
IMAP_PORT=993
